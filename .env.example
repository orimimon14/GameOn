# Public Firebase web config (ENVIRONMENTS §5) — safe to expose, protected by Security Rules.
# Copy to .env.local and fill with the values from Firebase Console → Project settings → Web app.
VITE_FIREBASE_API_KEY=replace-with-firebase-web-api-key
# Auth domain must match the domain users open the app on (mobile redirect
# flow needs same-origin state) AND be whitelisted on the Google OAuth client.
# Share the app at https://swish-game-dev.firebaseapp.com accordingly.
VITE_FIREBASE_AUTH_DOMAIN=swish-game-dev.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=swish-game-dev
VITE_FIREBASE_STORAGE_BUCKET=swish-game-dev.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=replace-with-messaging-sender-id
VITE_FIREBASE_APP_ID=replace-with-firebase-app-id

# Local development: connect the SDK to the local Emulator Suite.
VITE_USE_EMULATORS=true
